{
	"$schema": "https://biomejs.dev/schemas/2.4.2/schema.json",
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"src/**/*.ts",
			"!node_modules",
			"!src/__generated__",
			"!src/vendor"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"useLiteralKeys": "off"
			}
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"recommended": true,
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": true,
		"indentStyle": "tab"
	}
}
