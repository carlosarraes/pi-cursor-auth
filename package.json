{
  "name": "pi-cursor-auth",
  "version": "0.1.0",
  "description": "Cursor Agent provider for Pi — use Cursor's AI models via pi",
  "main": "./src/index.ts",
  "type": "module",
  "license": "MIT",
  "author": "carraes",
  "files": ["src", "proto"],
  "pi": {
    "extensions": ["./src"]
  },
  "scripts": {
    "lint": "biome check",
